# ========= CORE APP =========
APP_ENV=development
APP_NAME=L2 Core OS
TIMEZONE=America/Sao_Paulo
JWT_SECRET=change_me_please
JWT_ALGO=HS256
JWT_EXPIRES_MIN=60

# ========= PORTS =========
WEB_PORT=3000
API_PORT=8000
BAILEYS_PORT=8090
POSTGRES_PORT=5432
REDIS_PORT=6379

# ========= DATABASE =========
DB_MODE=local_postgres
POSTGRES_DB=l2core
POSTGRES_USER=l2
POSTGRES_PASSWORD=l2core_local
DATABASE_URL=postgresql://l2:l2core_local@db:5432/l2core

# ========= REDIS =========
REDIS_URL=redis://redis:6379/0

# ========= RBAC / SECURITY =========
RBAC_ENABLED=true
DEFAULT_OWNER_EMAIL=owner@local
RATE_LIMIT_IP_PER_MIN=60
RATE_LIMIT_TOKEN_PER_MIN=120
WEBHOOK_HMAC_SECRET=change_this_secret
WEBHOOK_REPLAY_WINDOW_SECONDS=300

# ========= BAILEYS =========
BAILEYS_SESSION_NAME=main
BAILEYS_QR_AUTO=true
BAILEYS_WEBHOOK_TARGET=http://api:8000/webhooks/whatsapp/inbound
BAILEYS_INTERNAL_TOKEN=change_internal_token
STARTUP_CATCHUP_HOURS=24
AUTO_MARK_READ=false
AUTO_REPLY_ONLY_SAFE_INTENTS=true
HUMAN_REVIEW_DEFAULT=true
WHATSAPP_NUMBER_MODE=primary

# ========= FEATURE FLAGS =========
FEATURE_INTENT_ROUTER=true
INTENT_ROUTER_PROVIDER=openrouter
INTENT_ROUTER_MODEL=openai/gpt-4o-mini
INTENT_ROUTER_MAX_COST_USD_DAY=2.0
INTENT_CONFIDENCE_THRESHOLD=0.78

# ========= MOBILE SYNC =========
MOBILE_SYNC_ENABLED=true
MOBILE_SYNC_POLL_SECONDS=20
MOBILE_DEVICE_BINDING_REQUIRED=true
